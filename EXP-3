#include <stdio.h>
 
int main(int argc, char *argv[]) {
FILE *src, *dest;
char ch;
printf("25331A05D9\n");
if (argc != 3) {
printf("Usage: ./copy source dest\n");
return 1;
}
src = fopen(argv[1], "r");
if (src == NULL) { printf("Cannot open source\n"); return 1; }
dest = fopen(argv[2], "w");
if (dest == NULL) { printf("Cannot open dest\n"); return 1; }
while ((ch = fgetc(src)) != EOF)
fputc(ch, dest);
fclose(src);
fclose(dest);
printf("File copied successfully!\n");
return 0;
}
